{
  "name": "notebook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client": "vite",
    "worker": "pnpm run build && wrangler dev",
    "dryrun": "pnpm run build && wrangler deploy --dry-run",
    "deploy": "pnpm run build && wrangler deploy ",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply notebook_db --local",
    "db:migrate": "wrangler d1 migrations apply notebook_db --remote"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fabric": "^7.4.0",
    "hono": "^4.12.29",
    "jose": "^6.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "tailwindcss": "^4.3.2",
    "wrangler": "^4.110.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "vite": "^8.1.1"
  }
}
